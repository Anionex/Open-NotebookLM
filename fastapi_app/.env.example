# ============================================
# Supabase Configuration (Optional)
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# Embedding Provider
# EMBEDDING_PROVIDER: local | openai | apiyi
#   local  → 本地 vllm 推理服务，无需 KEY
#   openai → OpenAI 或兼容接口（需要 KEY）
#   apiyi  → ApiYi 代理服务（需要 KEY）
# ============================================
EMBEDDING_PROVIDER=apiyi
EMBEDDING_API_URL=https://api.apiyi.com/v1
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# 本地 vllm embedding 示例：
# EMBEDDING_PROVIDER=local
# EMBEDDING_API_URL=http://localhost:8899/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=/path/to/your/embedding-model
# EMBEDDING_DIMENSION=2560

# ============================================
# TTS Provider
# TTS_PROVIDER: local | openai | apiyi | bailian
#   local   → 本地 TTS 服务，无需 KEY
#   openai  → OpenAI TTS 或兼容接口
#   apiyi   → ApiYi 代理（支持 qwen-tts 等）
#   bailian → 阿里云百炼 TTS
# ============================================
TTS_PROVIDER=apiyi
TTS_API_URL=https://api.apiyi.com/v1
TTS_API_KEY=your_tts_api_key
TTS_MODEL=qwen-tts

# 百炼 TTS 示例：
# TTS_PROVIDER=bailian
# TTS_API_URL=https://dashscope.aliyuncs.com/api/v1
# TTS_API_KEY=your_bailian_key
# TTS_MODEL=qwen3-tts-flash

# ============================================
# Image Generation Provider
# ============================================
IMAGE_GEN_API_URL=https://api.apiyi.com/v1
IMAGE_GEN_API_KEY=your_image_gen_api_key
IMAGE_GEN_MODEL=gemini-3-pro-image-preview

# ============================================
# LLM Provider
# ============================================
LLM_API_URL=https://api.apiyi.com/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gemini-2.5-flash

# ============================================
# Search Provider
# SEARCH_PROVIDER: serper | serpapi | bocha（默认 serper）
# ============================================
SEARCH_PROVIDER=serper
SERPER_API_KEY=your_serper_key_here
SERPAPI_KEY=your_serpapi_key_here
BOCHA_API_KEY=your_bocha_key_here
