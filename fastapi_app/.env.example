# ============================================
# Supabase Configuration (Optional)
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# Embedding Provider
# ============================================
EMBEDDING_API_URL=https://api.apiyi.com/v1
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ============================================
# Image Generation Provider
# ============================================
IMAGE_GEN_API_URL=https://api.apiyi.com/v1
IMAGE_GEN_API_KEY=your_api_key_here
IMAGE_GEN_MODEL=gemini-3-pro-image-preview

# ============================================
# TTS Provider
# ============================================
TTS_API_URL=https://api.apiyi.com/v1
TTS_API_KEY=your_api_key_here
TTS_MODEL=gemini-2.5-flash-tts

# 百炼 TTS (备选)
# TTS_API_URL=https://dashscope.aliyuncs.com/api/v1
# TTS_API_KEY=your_bailian_key_here
# TTS_MODEL=qwen3-tts-flash

# ============================================
# LLM Provider
# ============================================
LLM_API_URL=https://api.apiyi.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.5-flash

# ============================================
# Search Provider
# 选择一个 provider，填入对应 key 即可，其余留空
# ============================================
# SEARCH_PROVIDER: serper | serpapi | bocha（默认 serper）
SEARCH_PROVIDER=serper

# Serper（推荐，免费额度充足）
SERPER_API_KEY=your_serper_key_here

# SerpAPI（支持 Google / Baidu）
SERPAPI_KEY=your_serpapi_key_here

# 博查 Bocha（中文搜索友好）
BOCHA_API_KEY=your_bocha_key_here
